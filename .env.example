# Copy to .env and replace placeholder values.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=
GOOGLE_WEB_PROJECT_ID=
GOOGLE_WEB_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_WEB_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_WEB_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_WEB_REDIRECT_URI=

# Existing app-side key names for parity
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_REDIRECT_URI=appwrite-callback-<APPWRITE_PROJECT_ID>://google-oauth

# Optional: endpoint that returns mail OAuth vars from Appwrite (JSON)
# Example payload accepted by app:
# {
#   "GOOGLE_OAUTH_CLIENT_ID": "...",
#   "GOOGLE_OAUTH_REDIRECT_URI": "..."
# }
APPWRITE_MAIL_CONFIG_URL=
APPWRITE_MAIL_CONFIG_BEARER=
