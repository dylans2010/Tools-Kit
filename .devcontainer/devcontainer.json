{
  "name": "Swift iOS Dev Container (xtool + zsign + theos)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "hostRequirements": {
    "cpus": 4
  },
  "mounts": [
    "source=swift-spm-cache,target=/home/vscode/.cache/org.swift.swiftpm,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "sswg.swift-lang",
        "vadimcn.vscode-lldb"
      ],
      "settings": {
        "swift.path": "/usr/local/bin/swift",
        "lldb.library": "/usr/local/lib/swift/linux/liblldb.so",
        "editor.formatOnSave": true
      }
    }
  },
  "remoteUser": "vscode",
 "postCreateCommand": "swift --version && xtool --help && echo 'THEOS='$THEOS"
}